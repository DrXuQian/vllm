+#ifndef FLASHINFER_DECODE_KVFLOAT13_CUH_
+#define FLASHINFER_DECODE_KVFLOAT13_CUH_
+
+#include <cuda_bf16.h>
+#include <cuda_runtime.h>
+
+#define KVF13_SIGN_OFF   0
+#define KVF13_EXP_HI_OFF 16
+#define KVF13_EM_OFF     80
+#define KVF13_CHUNK_BYTES 208
